        "name": "get_garage",
        "title": "Get Garage Data",
        "description": "Read Garage vehicles, services, or servicings for the signed-in user.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "resource": {
              "type": "string",
              "enum": [
                "vehicles",
                "services",
                "servicings"
              ],
              "description": "Garage resource to read: vehicles, services, or servicings."
            },
            "vehicle_id": {
              "type": "string",
              "format": "uuid",
              "description": "Vehicle id required for services and servicings."
            },
            "id": {
              "$ref": "#/properties/vehicle_id",
              "description": "Optional record id to narrow the result."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500,
              "description": "Max rows to return."
            }
          },
          "required": [
            "resource"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "set_garage",
        "title": "Set Garage Data",
        "description": "Create, update, or delete Garage vehicles, services, or servicings for the signed-in user.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "resource": {
              "type": "string",
              "enum": [
                "vehicles",
                "services",
                "servicings"
              ]
            },
            "operation": {
              "type": "string",
              "enum": [
                "create",
                "update",
                "delete"
              ]
            },
            "id": {
              "type": "string",
              "format": "uuid",
              "description": "Record id required for update and delete."
            },
            "vehicle_id": {
              "$ref": "#/properties/id",
              "description": "Vehicle id required for service and servicing mutations."
            },
            "data": {
              "type": "object",
              "additionalProperties": {},
              "description": "Record fields for create or update. Owner fields are ignored."
            },
            "outcomes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "service_id": {
                    "$ref": "#/properties/id"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "performed",
                      "not_needed_yet",
                      "declined"
                    ],
                    "default": "performed"
                  }
                },
                "required": [
                  "service_id"
                ],
                "additionalProperties": false
              },
              "description": "Optional servicing service outcomes for servicings."
            }
          },
          "required": [
            "resource",
            "operation"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
