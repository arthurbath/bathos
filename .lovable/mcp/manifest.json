      {
        "name": "create_task",
        "title": "Create Task",
        "description": "Create one owner-scoped to-do with structured planning and source fields. A required idempotency key makes exact retries safe.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "idempotency_key": {
              "type": "string",
              "format": "uuid",
              "description": "Stable UUID for this logical creation request. Reuse it only to retry the exact same request."
            },
            "title": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            },
            "notes": {
              "type": "string",
              "maxLength": 100000,
              "default": ""
            },
            "destination": {
              "type": "string",
              "enum": [
                "inbox",
                "today",
                "anytime",
                "someday"
              ],
              "default": "inbox"
            },
            "today_section": {
              "type": "string",
              "enum": [
                "daytime",
                "evening"
              ],
              "default": "daytime"
            },
            "actionability": {
              "type": "string",
              "enum": [
                "actionable",
                "waiting"
              ],
              "default": "actionable",
              "description": "Whether the task can be acted on now or is waiting on something external."
            },
            "entry_channel": {
              "type": "string",
              "enum": [
                "mcp",
                "raycast",
                "browser_capture",
                "mail_automation",
                "native"
              ],
              "default": "mcp",
              "description": "Structured integration that collected the task. Ordinary MCP clients should keep the default."
            },
            "start_date": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "deadline": {
              "anyOf": [
                {
                  "$ref": "#/properties/start_date/anyOf/0"
                },
                {
                  "type": "null"
                }
              ]
            },
            "area_id": {
              "type": "string",
              "format": "uuid"
            },
            "project_id": {
              "$ref": "#/properties/area_id"
            },
            "heading_id": {
              "$ref": "#/properties/area_id"
            },
            "source": {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "webpage",
                    "mail_message",
                    "file",
                    "selected_text",
                    "reading_item",
                    "other"
                  ]
                },
                "url": {
                  "type": "string",
                  "maxLength": 8000
                },
                "title": {
                  "type": "string",
                  "maxLength": 1000
                },
                "external_id": {
                  "type": "string",
                  "maxLength": 2000
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false,
              "description": "Optional typed source reference. Template provenance is reserved for template instantiation."
            }
          },
          "required": [
            "idempotency_key",
            "title"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
